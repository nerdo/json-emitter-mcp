{
  "name": "json-emitter",
  "version": "0.1.0",
  "description": "MCP server that converts YAML to validated JSON — a safer emission surface for LLMs generating structured JSON payloads.",
  "type": "module",
  "private": true,
  "main": "dist/main.js",
  "bin": {
    "json-emitter": "dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "bun --hot src/main.ts",
    "build": "bun build src/main.ts --outdir dist --target node",
    "start": "bun dist/main.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "typecheck": "tsc --noEmit",
    "validate": "bun run test && bun run typecheck && bun run test && bun run build"
  },
  "keywords": ["mcp", "yaml", "json", "json-schema", "llm", "ajv"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "arktype": "^2.1.0",
    "ulid": "^2.3.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bun": "latest",
    "@types/node": "^24.0.0",
    "typescript": "^5.6.0"
  }
}
